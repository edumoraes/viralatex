#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if ! command -v pre-commit >/dev/null 2>&1; then
  printf 'FAIL: pre-commit is not installed.\n' >&2
  printf 'Install it first, then rerun this command.\n' >&2
  exit 1
fi

pre-commit install --install-hooks --hook-type pre-commit --hook-type pre-push
printf 'Installed pre-commit and pre-push hooks.\n'
