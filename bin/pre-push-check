#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

fail() {
  printf 'FAIL: %s\n' "$1" >&2
  exit 1
}

run() {
  printf '==> %s\n' "$*"
  "$@"
}

[[ -d "desktop/node_modules" ]] || fail "desktop dependencies are missing; run 'npm --prefix desktop install'."

run make test
run python3 -m unittest discover -s desktop/ai_service/tests -p 'test_*.py'
run npm --prefix desktop run test
run npm --prefix desktop run build
run cargo test --manifest-path desktop/src-tauri/Cargo.toml

printf 'Pre-push checks passed.\n'
