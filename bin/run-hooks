#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if ! command -v pre-commit >/dev/null 2>&1; then
  printf 'FAIL: pre-commit is not installed.\n' >&2
  exit 1
fi

pre-commit run --all-files
pre-commit run --hook-stage pre-push --all-files
